# fal.ai (필수)
FAL_KEY=your_fal_ai_key

# Gemini / YouTube (옵션)
GEMINI_API_KEY=
# (선택) 공식 SDK 호환용으로 동일 값 사용 가능
# GOOGLE_API_KEY=
# (선택) YouTube URL 직접 영상 분석(공식 Gemini preview 기능)용 모델명
# GEMINI_BENCHMARK_VIDEO_MODEL=gemini-3-flash-preview
# (선택) true면 YouTube URL 직접 영상 분석을 먼저 시도 후 실패 시 메타데이터/자막 폴백
# GEMINI_BENCHMARK_USE_YOUTUBE_URL=true
# (선택) true면 direct video 실패 시 메타데이터/자막 폴백 허용 (기본 false)
# GEMINI_BENCHMARK_ALLOW_METADATA_FALLBACK=false

# Studio YouTube 벤치마킹(메타데이터/자막 기반) 분석용 LLM 모델(OpenRouter model id, 옵션)
# OPENROUTER_BENCHMARK_MODEL=google/gemini-2.5-flash
# (레거시) GEMINI_BENCHMARK_MODEL=google/gemini-2.5-flash

# YouTube Data API v3 (트렌드 시그널용, 선택)
# https://console.cloud.google.com/apis/credentials 에서 API 키 생성 후 활성화: YouTube Data API v3
YOUTUBE_API_KEY=

# Vertex AI 웹 검색 (Grounding). worker에 전달. 미설정 시 코드 기본값 gemini-2.0-flash-001 사용.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_APPLICATION_CREDENTIALS=
# VERTEX_SEARCH_MODEL=gemini-2.0-flash-001

# CORS - 프론트 접속 오리진, 콤마 구분
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080,http://127.0.0.1:3000

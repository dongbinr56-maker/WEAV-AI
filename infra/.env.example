# fal.ai (필수)
FAL_KEY=your_fal_ai_key

# Google AI Studio Gemini API (유튜브 URL 벤치마킹 분석용)
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=
# (선택) 공식 SDK 호환용으로 동일 값 사용 가능
# GOOGLE_API_KEY=
# (선택) 벤치마킹 분석 전용 모델명
# GEMINI_BENCHMARK_MODEL=gemini-2.5-flash
# (선택) YouTube URL 직접 영상 분석(공식 Gemini preview 기능)용 모델명
# GEMINI_BENCHMARK_VIDEO_MODEL=gemini-3-flash-preview
# (선택) true면 YouTube URL 직접 영상 분석을 먼저 시도 후 실패 시 메타데이터/자막 폴백
# GEMINI_BENCHMARK_USE_YOUTUBE_URL=true
# (선택) true면 direct video 실패 시 메타데이터/자막 폴백 허용 (기본 false)
# GEMINI_BENCHMARK_ALLOW_METADATA_FALLBACK=false

# YouTube Data API v3 (트렌드 시그널용, 선택)
# https://console.cloud.google.com/apis/credentials 에서 API 키 생성 후 활성화: YouTube Data API v3
YOUTUBE_API_KEY=

# MinIO public endpoint (fal이 접근 가능한 도메인/포트)
# 예: media.your-domain.com:9000
# MINIO_PUBLIC_ENDPOINT=
# MINIO_PUBLIC_USE_SSL=false

# MinIO browser endpoint (프론트에서 이미지/문서 URL로 직접 열 수 있는 주소)
# Docker 로컬 개발 기본값은 localhost:9000 이 권장됩니다.
# MINIO_BROWSER_ENDPOINT=localhost:9000
# MINIO_BROWSER_USE_SSL=false

# (선택) MinIO 루트 계정. 프로덕션에서는 반드시 강한 비밀번호로 설정하세요.
# MINIO_ROOT_USER=weavai_admin
# MINIO_ROOT_PASSWORD=minio123

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api

# CORS - DEBUG=False일 때만 적용
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080,http://127.0.0.1:3000

# DB
DATABASE_URL=postgresql://weavai:weavai@localhost:5432/weavai

# Celery (Redis - 비동기 작업용)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI
FAL_KEY=your_fal_ai_key
GEMINI_API_KEY=
# (선택) 공식 SDK 호환용으로 동일 값 사용 가능
# GOOGLE_API_KEY=
# (선택) YouTube URL 직접 영상 분석(공식 Gemini preview 기능)용 모델명
# GEMINI_BENCHMARK_VIDEO_MODEL=gemini-3-flash-preview
# (선택) true면 YouTube URL 직접 영상 분석을 먼저 시도 후 실패 시 메타데이터/자막 폴백
# GEMINI_BENCHMARK_USE_YOUTUBE_URL=true
# (선택) true면 direct video 실패 시 메타데이터/자막 폴백 허용 (기본 false)
# GEMINI_BENCHMARK_ALLOW_METADATA_FALLBACK=false

# Studio YouTube 벤치마킹(메타데이터/자막 기반) 분석용 LLM 모델(OpenRouter model id, 옵션)
# OPENROUTER_BENCHMARK_MODEL=google/gemini-2.5-flash
# (레거시) GEMINI_BENCHMARK_MODEL=google/gemini-2.5-flash

# Vertex AI 웹 검색 (Grounding with Google Search)
# 검색용 모델 명시. 미설정 시 코드 기본값 gemini-2.0-flash-001 사용.
# VERTEX_SEARCH_MODEL=gemini-2.0-flash-001

# MinIO public endpoint (fal이 접근 가능한 도메인/포트)
# 예: media.your-domain.com:9000
# MINIO_PUBLIC_ENDPOINT=
# MINIO_PUBLIC_USE_SSL=false

# MinIO browser endpoint (프론트에서 이미지/문서 URL로 직접 열 수 있는 주소)
# Docker 로컬 개발 기본값은 localhost:9000 이 권장됩니다.
# MINIO_BROWSER_ENDPOINT=localhost:9000
# MINIO_BROWSER_USE_SSL=false

# MinIO (docker-compose 기본값과 일치)
# 프로덕션에서는 MINIO_ACCESS_KEY, MINIO_SECRET_KEY를 강한 값으로 반드시 설정하세요.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=weavai_admin
MINIO_SECRET_KEY=minio123
MINIO_BUCKET_NAME=weav-ai

# YouTube Data API v3 (Trend Signals 인기 영상)
YOUTUBE_API_KEY=
